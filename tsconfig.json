// tsconfig.json (Minimal for JSDoc and Types)
{
  "compilerOptions": {
    "allowJs": true, 
    "checkJs": false,
    "module": "ESNext",
    "moduleResolution": "Node",
    "declaration": true,
    "rootDir": "src",
    "outDir": "./dist/es",  
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}